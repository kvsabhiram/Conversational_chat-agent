# Copy to deploy/.env on the server. The EC2 user-data script generates this
# automatically with random secrets. Values here are illustrative only.

# Which GGUF llama.cpp loads. Any ungated instruct GGUF works via /v1/chat/completions.
# Gemma 3 is what the app's prompt template targets. Swap freely, e.g.:
#   unsloth/gemma-3-4b-it-GGUF:Q4_K_M   (smaller/faster, ~2.5GB)
#   unsloth/gemma-3-12b-it-GGUF:Q4_K_M  (default, better quality, ~7GB)
LLAMA_MODEL=unsloth/gemma-3-12b-it-GGUF:Q4_K_M
LLAMA_CTX=8192

# Container image tag to run (a git SHA). The CI/CD deploy job sets this to the
# commit it just built + pushed to GHCR. Falls back to :latest if unset.
IMAGE_TAG=latest

# Secrets (generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=change-me
API_SECRET_KEY=change-me
