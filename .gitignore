# ============ Secrets / environment ============
# Never commit real credentials (DB passwords, API keys, secret keys).
# Keep .env.example as the tracked template.
.env
.env.*
!.env.example

# ============ Python ============
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Virtual environments ----
Agent_env/
.venv/
venv/
env/
ENV/

